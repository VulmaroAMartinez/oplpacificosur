{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "corporate/hero",
    "title": "Hero Corporativo",
    "category": "design",
    "icon": "cover-image",
    "description": "Sección Hero principal con imagen de fondo y llamadas a la acción.",
    "attributes": {
        "bgImageUrl": {
            "type": "string"
        },
        "bgImageId": {
            "type": "number"
        },
        "subtitle": {
            "type": "string",
            "default": "Agente naviero y operador logístico"
        },
        "titleStart": {
            "type": "string",
            "default": "Conectamos el mundo."
        },
        "titleHighlight": {
            "type": "string",
            "default": "Conectamos oportunidades."
        },
        "description": {
            "type": "string",
            "default": "En OPL Pacífico Sur creemos que el mar no solo conecta puertos, sino también oportunidades."
        },
        "ctaQuoteText": {
            "type": "string",
            "default": "SOLICITAR COTIZACIÓN"
        },
        "ctaQuoteUrl": {
            "type": "string",
            "default": "/contacto"
        },
        "ctaServicesText": {
            "type": "string",
            "default": "NUESTROS SERVICIOS"
        },
        "ctaServicesUrl": {
            "type": "string",
            "default": "/servicios"
        }
    },
    "editorScript": "file:./index.js"
}